---
import BaseLayout from "@layouts/BaseLayout.astro";
import Container from "@components/Container.astro";
import ContactForm from "@components/ContactForm.astro";
import { SITE } from "@lib/site";

const title = "Contact | Sollicitatiebriefvoorbeeld.nl";
const description =
  "Een specifiek beroep waarvoor je een voorbeeld mist, of vragen over de toon van jouw brief? Stuur een bericht via het contactformulier.";
---

<BaseLayout title={title} description={description}>
  <Fragment slot="jsonld">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "ContactPage",
      "name": "Contact " + SITE.name,
      "url": `${SITE.url}/contact/`,
      "description": description,
      "inLanguage": "nl-NL",
      "isPartOf": {
        "@type": "WebSite",
        "name": SITE.name,
        "url": SITE.url,
      },
    })} />
  </Fragment>

  <Container as="section" class="section-pad">
    <div class="grid gap-12 lg:grid-cols-[2fr,3fr] max-w-5xl">
      <div>
        <p class="text-xs font-medium uppercase tracking-wider text-brand-700 dark:text-brand-400">
          Contact
        </p>
        <h1 class="mt-3">Stuur ons een bericht</h1>
        <p class="mt-6 text-lg text-[color:var(--text-muted)]">
          Heb je een scherpe vraag, wil je reageren op een artikel of lijkt een
          samenwerking je interessant? Laat het ons weten via het formulier of
          per mail. We houden van goede ideeën en een helder gesprek.
        </p>
        <p class="mt-6 text-sm text-[color:var(--text-muted)]">
          Reactie meestal binnen 2 werkdagen.
        </p>
      </div>

      <div class="rounded-2xl border border-[color:var(--border)] bg-[color:var(--surface)] p-8 shadow-sm">
        <h2 class="text-xl font-display font-semibold mb-6">Contactformulier</h2>
        <ContactForm />
      </div>
    </div>
  </Container>
</BaseLayout>
