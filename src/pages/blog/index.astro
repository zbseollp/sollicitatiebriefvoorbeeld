---
import BaseLayout from "@layouts/BaseLayout.astro";
import Container from "@components/Container.astro";
import BlogPostCard from "@components/BlogPostCard.astro";
import { SITE } from "@lib/site";
import { getAllPosts, getRecentPosts, postUrl } from "@lib/posts";

const allPosts = await getAllPosts();
const recentPosts = (await getRecentPosts(6)).map((p) => ({ slug: p.id, title: p.data.title }));

const title = `Alle artikelen | ${SITE.name}`;
const description = `Alle artikelen op ${SITE.domain}.`;
---

<BaseLayout title={title} description={description} recentPosts={recentPosts}>
  <Container as="section" class="section-pad">
    <h1 class="mt-3">Alle artikelen</h1>
    <p class="mt-4 max-w-3xl text-lg text-[color:var(--text-muted)]">
      Welkom op de artikelenpagina van {SITE.name}. Hier vind je al onze stukken, gerangschikt op datum.
    </p>

    <div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {allPosts.map((post, i) => {
        const catName = post.data.categories[0];
        return (
          <BlogPostCard
            href={postUrl(post)}
            title={post.data.title}
            excerpt={post.data.metaDescription}
            date={post.data.date}
            image={post.data.featuredImage}
            imageAlt={post.data.featuredImageAlt}
            category={catName}
            priority={i === 0}
          />
        );
      })}
    </div>
  </Container>
</BaseLayout>
