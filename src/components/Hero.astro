---
interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  ctaLabel?: string;
  ctaHref?: string;
  secondaryLabel?: string;
  secondaryHref?: string;
}
const {
  eyebrow,
  title,
  subtitle,
  ctaLabel,
  ctaHref,
  secondaryLabel,
  secondaryHref,
} = Astro.props;
---

<section class="relative overflow-hidden">
  <!-- Subtle gradient backdrop -->
  <div
    class="absolute inset-0 -z-10 opacity-60 dark:opacity-30 pointer-events-none"
    aria-hidden="true"
  >
    <div class="absolute top-0 -right-32 h-[40rem] w-[40rem] rounded-full bg-brand-200/40 dark:bg-brand-600/20 blur-3xl"></div>
    <div class="absolute -bottom-40 -left-20 h-[30rem] w-[30rem] rounded-full bg-brand-100/60 dark:bg-brand-700/10 blur-3xl"></div>
  </div>

  <div class="container-page pt-10 pb-8 md:pt-16 md:pb-12 lg:pt-20 lg:pb-16">
    <div class="max-w-3xl">
      {eyebrow && (
        <p class="mb-6 inline-flex items-center gap-2 rounded-full border border-[color:var(--border)] bg-[color:var(--surface)] px-4 py-1.5 text-xs font-medium uppercase tracking-wider text-brand-700 dark:text-brand-400">
          {eyebrow}
        </p>
      )}
      <h1 class="text-balance">
        {title}
      </h1>
      {subtitle && (
        <p class="mt-5 text-lg md:text-xl text-[color:var(--text-muted)] max-w-2xl">
          {subtitle}
        </p>
      )}
      {(ctaLabel || secondaryLabel) && (
        <div class="mt-7 flex flex-wrap gap-3">
          {ctaLabel && ctaHref && (
            <a href={ctaHref} class="inline-flex h-12 items-center justify-center rounded-full bg-brand-700 hover:bg-brand-800 dark:bg-brand-500 dark:hover:bg-brand-400 px-7 text-base font-medium text-white dark:text-ink-950 shadow-sm hover:shadow transition-all">
              {ctaLabel}
            </a>
          )}
          {secondaryLabel && secondaryHref && (
            <a href={secondaryHref} class="inline-flex h-12 items-center justify-center rounded-full border border-[color:var(--border)] bg-[color:var(--surface)] hover:bg-ink-100 dark:hover:bg-ink-800 px-7 text-base font-medium text-[color:var(--text)] transition-all">
              {secondaryLabel}
            </a>
          )}
        </div>
      )}
    </div>
  </div>
</section>
