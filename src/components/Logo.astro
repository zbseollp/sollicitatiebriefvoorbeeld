---
interface Props {
  showText?: boolean;
  iconClass?: string;
  textClass?: string;
  class?: string;
}
const {
  showText = true,
  iconClass = "h-9 w-9",
  textClass = "text-base md:text-lg",
  class: className = "",
} = Astro.props;
---

<a
  href="/"
  class:list={["inline-flex items-center gap-2.5 group", className]}
  aria-label="Sollicitatiebriefvoorbeeld home"
>
  <svg
    class:list={[iconClass, "flex-shrink-0"]}
    viewBox="0 0 40 40"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
    aria-hidden="true"
  >
    <path d="M8 5 H 26 L 33 12 V 35 H 8 Z" fill="var(--color-paper-50)" stroke="var(--color-brand-900)" stroke-width="1.6" stroke-linejoin="round"/>
    <path d="M26 5 V 12 H 33" fill="var(--color-accent-200)" stroke="var(--color-brand-900)" stroke-width="1.6" stroke-linejoin="round"/>
    <line x1="12" y1="17" x2="29" y2="17" stroke="var(--color-brand-700)" stroke-width="1.2" stroke-linecap="round"/>
    <line x1="12" y1="22" x2="26" y2="22" stroke="var(--color-brand-700)" stroke-width="1.2" stroke-linecap="round"/>
    <line x1="12" y1="27" x2="29" y2="27" stroke="var(--color-brand-700)" stroke-width="1.2" stroke-linecap="round"/>
    <line x1="12" y1="31" x2="20" y2="31" stroke="var(--color-accent-500)" stroke-width="1.8" stroke-linecap="round"/>
  </svg>
  {showText && (
    <span
      class:list={[
        "font-display font-bold tracking-tight text-[color:var(--text)] transition-colors leading-tight",
        textClass,
      ]}
    >
      sollicitatie<wbr/>brief<span class="text-[color:var(--color-accent-500)]">·</span>voorbeeld
    </span>
  )}
</a>
